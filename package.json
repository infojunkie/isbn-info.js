{
  "name": "isbn-info",
  "version": "3.1.0",
  "description": "Console tools to identify books by their ISBN and output formatted metadata.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/infojunkie/isbn-info.git"
  },
  "bin": {
    "isbn-format": "build/isbn-format.js",
    "isbn-detect": "build/isbn-detect.js",
    "isbn-extract": "src/isbn-extract.sh",
    "isbn-bulk-rename": "src/isbn-bulk-rename.sh"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "mocha --require tsx test/**/*.test.ts"
  },
  "author": "Karim Ratib <karim.ratib@gmail.com> (https://github.com/infojunkie)",
  "license": "GPL-3.0-only",
  "files": [
    "LICENSE.txt",
    "build/*",
    "src/isbn-bulk-rename.sh",
    "src/isbn-extract.sh"
  ],
  "dependencies": {
    "isbn3": "^1.1.19",
    "issn": "^1.0.6",
    "meow": "^10.1.2",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.19.43",
    "@types/sinon": "^17.0.3",
    "chai": "^4.4.1",
    "mocha": "^10.0.0",
    "sinon": "^13.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
